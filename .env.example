# --- General ---
PUID=1000
PGID=1000
TZ=America/New_York

# --- MongoDB (used by both mongo and unifi services) ---
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=CHANGEME_root_password
MONGO_USER=unifi
MONGO_PASS=CHANGEME_unifi_password
MONGO_DBNAME=unifi
MONGO_AUTHSOURCE=admin

# --- UniFi Network Application ---
# Max heap in MB — 1024 is comfortable on a Pi 5 with 8GB
MEM_LIMIT=1024
MEM_STARTUP=1024
